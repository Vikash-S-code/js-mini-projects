{
    "manifest_version": 3,
    "name": "Notes App",
    "version": "1.0",
    "description": "A simple notes app Chrome extension",
    "action": {
      "default_title": "Open Notes",
      "default_popup": "popup.html"
    },
    "permissions": ["tabs"],
    "host_permissions": [
      "https://*/*",
      "http://*/*"
    ],
    "web_accessible_resources": [
      {
        "resources": ["NotesApp.html"],
        "matches": ["<all_urls>"]
      }
    ]
  }